# EGen Platform Environment Configuration

# API Keys
HUGGINGFACE_API_KEY=your_huggingface_api_key
OPENAI_API_KEY=your_openai_api_key
WANDB_API_KEY=your_wandb_api_key

# Model Configuration
MODEL_PATH=./models/thl150
MODEL_PRECISION=fp16  # Options: fp32, fp16, int8, int4

# Training Configuration
BATCH_SIZE=32
LEARNING_RATE=5e-5
GRADIENT_ACCUMULATION_STEPS=4
MAX_EPOCHS=10

# Deployment Configuration
DEPLOYMENT_MODE=development  # Options: development, production
API_HOST=0.0.0.0
API_PORT=8000
WEB_UI_PORT=8501

# Monitoring Configuration
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200

# Security Configuration
ENABLE_AUTH=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_immediately
JWT_SECRET=generate_a_secure_random_string

# Logging Configuration
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json  # Options: json, text

# Resource Limits
MAX_GPU_MEMORY=16GB
MAX_CPU_CORES=8
MAX_RAM=32GB